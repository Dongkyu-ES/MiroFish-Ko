# LLM API 설정 (OpenAI SDK 형식을 따르는 모든 LLM API 지원)
# 권장 모델: 알리바바 바이롄 qwen-plus https://bailian.console.aliyun.com/
# 사용량이 클 수 있으므로 먼저 40라운드 미만으로 테스트해 보세요.
SECRET_KEY=your_secret_key_here
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP 메모리 그래프 설정 =====
# 월간 무료 한도로도 기본 사용이 가능합니다: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Graph Backend Mode =====
# zep | shadow_eval | local_primary
GRAPH_BACKEND=zep

# ===== Standalone Parity Engine =====
ENGINE_BASE_URL=http://127.0.0.1:8123
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8123
ENGINE_TIMEOUT_SECONDS=30

# ===== Graphiti Core =====
GRAPHITI_BACKEND=kuzu
GRAPHITI_DB_PATH=./data/graphiti.kuzu
GRAPHITI_PARITY_ARTIFACT_DIR=./artifacts/parity
GRAPHITI_DEFAULT_LANGUAGES=ko,en
GRAPHITI_STDOUT_LOGGING=true

# ===== Graphiti OpenAI-Compatible Provider =====
GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_BASE_URL=https://api.openai.com/v1
GRAPHITI_LLM_API_KEY=your_graphiti_llm_key_here
GRAPHITI_LLM_MODEL=gpt-4.1-mini
GRAPHITI_EMBEDDING_BASE_URL=https://api.openai.com/v1
GRAPHITI_EMBEDDING_API_KEY=your_graphiti_embedding_key_here
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small
GRAPHITI_RERANK_BASE_URL=https://api.openai.com/v1
GRAPHITI_RERANK_API_KEY=your_graphiti_rerank_key_here
GRAPHITI_RERANK_MODEL=gpt-4.1-mini

# ===== LLM 가속 설정 (선택) =====
# 가속 설정을 사용하지 않는다면 아래 항목은 env 파일에 넣지 마세요.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Local Graph Engine / Parity Engine =====
GRAPH_BACKEND=zep
ENGINE_BASE_URL=http://127.0.0.1:8123
ENGINE_HOST=127.0.0.1
ENGINE_PORT=8123
ENGINE_TIMEOUT_SECONDS=30
ENGINE_SHADOW_EVAL_ENABLED=false
ENGINE_SHARED_TOKEN=your_engine_shared_token_here

GRAPHITI_BACKEND=kuzu
GRAPHITI_DB_PATH=./data/graphiti.kuzu
GRAPHITI_DEFAULT_LANGUAGES=ko,en
GRAPHITI_STDOUT_LOGGING=true

GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_BASE_URL=https://api.openai.com/v1
GRAPHITI_LLM_API_KEY=your_graphiti_llm_key_here
GRAPHITI_LLM_MODEL=gpt-4.1-mini

GRAPHITI_EMBEDDING_BASE_URL=https://api.openai.com/v1
GRAPHITI_EMBEDDING_API_KEY=your_graphiti_embedding_key_here
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-large

GRAPHITI_RERANK_BASE_URL=https://api.openai.com/v1
GRAPHITI_RERANK_API_KEY=your_graphiti_rerank_key_here
GRAPHITI_RERANK_MODEL=gpt-4.1-mini
