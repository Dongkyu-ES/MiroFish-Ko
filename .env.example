# ===== LLM Provider 설정 =====
# 현재 백엔드는 Codex CLI + Claude cli 사용합니다.
LLM_PROVIDER=codex_cli

# ===== Codex CLI 설정 =====
# CODEX_BIN은 보통 codex 그대로 두면 됩니다.
CODEX_BIN=codex
CODEX_JSON_MODEL=gpt-5.4-mini
CODEX_REASONING_MODEL=gpt-5.4
CODEX_JSON_REASONING_EFFORT=high
CODEX_REASONING_EFFORT=high
CODEX_SERVICE_TIER=fast
CODEX_SANDBOX=read-only
CODEX_TIMEOUT_JSON_SEC=120
CODEX_TIMEOUT_REASONING_SEC=600

# ===== 그래프 백엔드 설정 =====
# 현재 기본값은 local_sqlite
GRAPH_BACKEND=backend/uploads/local_graphs.sqlite3
LOCAL_GRAPH_DB_PATH=backend/uploads/local_graphs.sqlite3

# ===== Claude CLI 폴백 설정 (선택) =====
# Codex CLI 1차 폴백도 실패 시 Claude CLI로 2차 폴백합니다.
# 활성화하려면 CLAUDE_FALLBACK_ENABLED=true로 설정하세요.
CLAUDE_FALLBACK_ENABLED=true
CLAUDE_BIN=claude
CLAUDE_MODEL_REASONING=claude-opus-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_TIMEOUT_SEC=120

# ===== OASIS 시뮬레이션 CLI 백엔드 설정 =====
# LLM_BACKEND=cli 로 설정하면 API 키 없이 Codex/Claude CLI로 직접 호출합니다.
# CLAUDE_PRIMARY=true 면 Claude CLI 우선, 아니면 Codex CLI 우선.
LLM_BACKEND=cli

# ===== OASIS 시뮬레이션 모델 폴백 설정 =====
# camel-ai가 OpenAI API 직접 호출 시 모델 404/레이트리밋이면 Claude로 폴백
 OASIS_FALLBACK_ENABLED=true
 OASIS_FALLBACK_MODEL=claude-haiku-4-5

# ===== LLM Fast Backend (config/profile 생성용) =====
# gemini = Gemini API 직접 호출 (빠름, 무료)
# 비워두면 기존 Codex/Claude CLI 경로 사용
LLM_FAST_BACKEND=gemini
GEMINI_API_KEY=
OASIS_GEMINI_MODEL=gemini-2.0-flash
